DATAFORGE_OUTPUT_MODE=local
DATAFORGE_S3_OUTPUT_PATH=s3://dataforge-kerchunks/kerchunks
DATAFORGE_WORKSPACE=
DATAFORGE_REDIS_URL=redis://localhost:6379/1
DATAFORGE_BROKER_REDIS_URL=redis://localhost:6379/0
DATAFORGE_API_URL=http://127.0.0.1:8000
# Optional for local S3-compatible development.
# DATAFORGE_S3_ENDPOINT_URL=http://127.0.0.1:3900

# Dask parallelization settings (Stage 5)
# DATAFORGE_DASK_N_WORKERS=           # auto = based on available CPUs
# DATAFORGE_DASK_THREADS_PER_WORKER=1 # 1 is safest for HDF5/kerchunk
# DATAFORGE_DASK_MEMORY_LIMIT=2GiB    # per-worker memory limit
# DATAFORGE_DASK_PROCESSES=true        # use processes (true) or threads (false)
# DATAFORGE_DASK_PARALLEL_THRESHOLD=4  # min files before Dask kicks in
